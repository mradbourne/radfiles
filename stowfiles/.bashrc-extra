# ~/.path is used to extend `$PATH`.
# ~/.extra is used for other settings you don’t want to commit.
for file in $HOME/.{path,exports,functions,aliases,extra}; do
    [ -r "$file" ] && [ -f "$file" ] && . "$file"
done
unset file

# Homebrew
if command -v brew &> /dev/null; then
    eval "$(brew shellenv)"
fi

# pyenv
if command -v pyenv &> /dev/null; then
    export PYENV_ROOT="$HOME/.pyenv"
    [[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
fi
